@page
@model proiect.web.Pages.IndexModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>Plan Alimentar Personalizat</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            height: 100%;
            width: 100%;
        }

        body {
            font-family: Arial, sans-serif;
            background: url('/pozaBackgroundSite.png') no-repeat center center fixed;
            background-size: cover;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: flex-start;
            min-height: 100vh;
            padding: 20px;
        }

        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.4);
            z-index: -1;
        }

        .card {
            background: rgba(255, 255, 255, 0.80);
            padding: 40px;
            border-radius: 12px;
            max-width: 900px;
            width: 100%;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
            color: #1c1c1c;
            margin-top: 60px;
        }

        .card h2 {
            text-align: center;
            margin-bottom: 30px;
            font-size: 28px;
            color: #333;
        }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
            margin-bottom: 20px;
        }

        .form-group {
            display: flex;
            flex-direction: column;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            color: #333;
            font-size: 14px;
        }

        .form-group input, .form-group select {
            width: 100%;
            padding: 12px;
            border: 1px solid #ddd;
            border-radius: 4px;
            font-size: 14px;
            background-color: #f9f9f9;
            color: #333;
            transition: border-color 0.3s, background-color 0.3s;
        }

        .form-group input:focus, .form-group select:focus {
            outline: none;
            border-color: #007bff;
            background-color: #fff;
            box-shadow: 0 0 5px rgba(0, 123, 255, 0.2);
        }

        .form-group input::placeholder {
            color: #999;
        }

        .btn {
            background: #007bff;
            color: white;
            border: none;
            padding: 14px;
            border-radius: 4px;
            cursor: pointer;
            width: 100%;
            font-size: 16px;
            font-weight: bold;
            margin-top: 20px;
            transition: background 0.3s;
        }

        .btn:hover {
            background: #0056b3;
        }

        .result {
            margin-top: 20px;
            padding: 15px;
            background: #d4edda;
            border-left: 4px solid #28a745;
            border-radius: 4px;
            color: #155724;
            font-weight: 500;
            line-height: 1.6;
        }

        .error {
            background: #f8d7da;
            border-left: 4px solid #dc3545;
            color: #721c24;
        }

        .result-card {
            background: rgba(255, 255, 255, 0.80);
            padding: 30px;
            border-radius: 12px;
            max-width: 900px;
            width: 100%;
            margin-top: 20px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
        }

        .meal-plan-title {
            text-align: center;
            font-size: 26px;
            font-weight: bold;
            margin-bottom: 30px;
            color: #333;
        }

        .week-container {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 25px;
            margin-bottom: 20px;
        }

        .day-card {
            background: #fff;
            border-left: 4px solid #007bff;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        }

        .day-card h3 {
            color: #007bff;
            font-size: 18px;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .meal-group {
            margin-bottom: 20px;
        }

        .meal-group-title {
            display: flex;
            align-items: center;
            gap: 8px;
            font-weight: bold;
            color: #333;
            font-size: 13px;
            text-transform: uppercase;
            margin-bottom: 10px;
            padding-bottom: 8px;
            border-bottom: 1px solid #ddd;
        }

        .meal-item {
            margin-bottom: 12px;
            padding-left: 10px;
            padding-bottom: 12px;
            border-bottom: 1px solid #f0f0f0;
        }

        .meal-item:last-child {
            border-bottom: none;
            margin-bottom: 0;
            padding-bottom: 0;
        }

        .meal-name {
            font-weight: bold;
            color: #333;
            font-size: 14px;
            margin-bottom: 5px;
        }

        .meal-details {
            font-size: 12px;
            color: #666;
        }

        .day-summary {
            background: #f8f9ff;
            padding: 12px;
            border-radius: 6px;
            margin-top: 15px;
            text-align: center;
            font-weight: bold;
            color: #007bff;
            font-size: 14px;
        }

        .btn-download {
            display: inline-block;
            background: #28a745;
            color: white;
            padding: 14px 32px;
            border-radius: 4px;
            text-decoration: none;
            font-weight: bold;
            font-size: 16px;
            transition: background 0.3s;
            border: none;
            cursor: pointer;
        }

        .btn-download:hover {
            background: #218838;
        }

        .meal-item {
            position: relative;
            transition: background-color 0.2s;
        }

        .meal-item:hover {
            background-color: rgba(0, 123, 255, 0.05);
            border-radius: 4px;
        }

        .btn-swap {
            background: #ffc107;
            color: #333;
            border: none;
            padding: 6px 12px;
            border-radius: 4px;
            cursor: pointer;
            font-size: 12px;
            font-weight: bold;
            margin-top: 8px;
            transition: background 0.3s;
            display: none;
        }

        .btn-swap:hover {
            background: #ffca2c;
        }

        .modal-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.6);
            z-index: 1000;
            justify-content: center;
            align-items: center;
        }

        .modal-content {
            background: white;
            padding: 30px;
            border-radius: 12px;
            max-width: 500px;
            width: 90%;
            max-height: 80vh;
            overflow-y: auto;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            padding-bottom: 15px;
            border-bottom: 1px solid #ddd;
        }

        .modal-header h3 {
            margin: 0;
            color: #333;
            font-size: 18px;
        }

        .modal-close {
            background: none;
            border: none;
            font-size: 24px;
            cursor: pointer;
            color: #999;
        }

        .modal-close:hover {
            color: #333;
        }

        .alternative-option {
            padding: 12px;
            border: 1px solid #ddd;
            border-radius: 6px;
            margin-bottom: 10px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .alternative-option:hover {
            background: #f8f9ff;
            border-color: #007bff;
        }

        .alternative-name {
            font-weight: bold;
            color: #333;
            font-size: 14px;
        }

        .alternative-details {
            font-size: 12px;
            color: #666;
            margin-top: 4px;
        }

        .no-alternatives {
            text-align: center;
            color: #666;
            padding: 20px;
        }
    </style>
</head>
<body>

    <div class="card">
        <h2>⚙️ Seteaza Obiectivul Tau</h2>

        @Html.AntiForgeryToken()
        
        <form method="post" asp-page-handler="GeneratePlan">
            <div class="form-row">
                <div class="form-group">
                    <label>Sex</label>
                    <select asp-for="Sex">
                        <option value="M">Masculin</option>
                        <option value="F">Feminin</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Varsta (ani)</label>
                    <input asp-for="Varsta" type="number" placeholder="25" />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>Greutate Actuala (kg)</label>
                    <input asp-for="Greutate" type="number" placeholder="85" />
                </div>
                <div class="form-group">
                    <label>Inaltime (cm)</label>
                    <input asp-for="Inaltime" type="number" placeholder="180" />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>Nivel de Activitate</label>
                    <select asp-for="Activitate">
                        <option value="sedentar">🪑 Sedentar (putin exercitiu)</option>
                        <option value="usoareactiv">🚶 Usor activ (1-3 zile/saptamana)</option>
                        <option value="moderat" >🏃 Moderat activ (3-5 zile/saptamana)</option>
                        <option value="activ">💪 Foarte activ (6-7 zile/saptamana)</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Obiectiv</label> 
                    <select asp-for="Obiectiv">
                        <option value="mentime">🎯 Sa-mi mentin greutatea</option>
                        <option value="slabire_usoara">📉 Slabire usoara (300 kcal deficit)</option>
                        <option value="slabire_normala">📉📉 Slabire normala (500 kcal deficit)</option>
                    </select>
                </div>
            </div>

            <button class="btn" type="submit">🍽️ Genereaza Plan Alimentar</button>

        </form>
        <form method="post" asp-page-handler="SendEmail">
            <div class="form-group" style="margin-top:20px;">
                <label>📧 Vrei sa fii la curent cu toate noutatile noastre?</label>
                <input asp-for="EmailDestinatar" type="email" placeholder="ex: nume@email.com" />
            </div>

            <button class="btn" type="submit">📨 Trimite Email</button>
        </form>
        @if (!string.IsNullOrEmpty(Model.MessageResult))
        {
            <div class="result">@Model.MessageResult</div>
        }

        <!-- Erori pentru Plan Alimentar -->
        @if (!string.IsNullOrEmpty(Model.ErrorMessage) && !Model.HasCalculated)
        {
            <div class="result error">@Model.ErrorMessage</div>
        }

        <!-- Erori pentru Email (SEPARATE) -->
        @if (!string.IsNullOrEmpty(Model.EmailErrorMessage))
        {
            <div class="result error">@Model.EmailErrorMessage</div>
        }
    </div>

    @if (Model.HasCalculated)
    {
        <!-- CSRF Token pentru request-uri AJAX -->
        <input type="hidden" id="csrfToken" name="__RequestVerificationToken" value="@Html.AntiForgeryToken().ToString()" />
        
        <div class="result-card">
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="result error">@Model.ErrorMessage</div>
            }
            else
            {
                <div class="result">@Html.Raw(Model.ResultSummary)</div>

                @if (Model.WeeklyPlan.Count > 0)
                {
                    @if (!string.IsNullOrEmpty(Model.PdfUrl))
                    {
                        <p style="text-align: center; margin: 20px 0;">
                            <a href="@Model.PdfUrl" class="btn-download" target="_blank" download>
                                📥 Descarca Raport PDF
                            </a>
                        </p>
                    }

                    <div class="meal-plan-title">📅 Planul tau alimentar pe 7 zile</div>

                    <div class="week-container">
                        @for (int day = 1; day <= 7; day++)
                        {
                            if (Model.WeeklyPlan.ContainsKey(day))
                            {
                                var dayMeals = Model.WeeklyPlan[day];
                                var daySummary = Model.DaySummaries[day];
                                var dayNames = new[] { "", "Luni", "Marti", "Miercuri", "Joi", "Vineri", "Sambata", "Duminica" };

                                <div class="day-card">
                                    <h3>Ziua @day - @dayNames[day]</h3>

                                    @{
                                        var mealGroups = dayMeals
                                            .GroupBy(m => m.MealType)
                                            .OrderBy(g => new[] { "mic_dejun", "pranz", "cina", "gustare" }.IndexOf(g.Key));
                                    }

                                    @foreach (var group in mealGroups)
                                    {
                                        var firstMeal = group.First();
                                        var mealLabel = firstMeal.GetMealLabel();
                                        var mealEmoji = firstMeal.GetMealEmoji();
                                        var groupTotal = group.Sum(m => m.Calories);
                                        var groupProtein = group.Sum(m => m.Protein);

                                        <div class="meal-group">
                                            <div class="meal-group-title">
                                                <span>@mealEmoji @mealLabel</span>
                                            </div>

                                            @foreach (var meal in group)
                                            {
                                                var mealIndex = Model.WeeklyPlan[day].IndexOf(meal);
                                                <div class="meal-item" 
                                                     data-food-id="@meal.Id" 
                                                     data-day="@day" 
                                                     data-meal-index="@mealIndex"
                                                     onmouseenter="showSwapButton(this)" 
                                                     onmouseleave="hideSwapButton(this)">
                                                    <div class="meal-name">@meal.Name</div>
                                                    <div class="meal-details">@meal.Calories.ToString("F0") kcal | @meal.Protein.ToString("F1")g proteina</div>
                                                    <button class="btn-swap" onclick="openSwapModal(@meal.Id, '@meal.MealType', @day, @mealIndex)" style="display:none;">
                                                        🔄 Nu îmi place, altceva
                                                    </button>
                                                </div>
                                            }

                                            <div style="padding-left: 10px; font-size: 12px; font-weight: bold; color: #007bff; margin-bottom: 10px;">
                                                Subtotal: @groupTotal.ToString("F0") kcal | @groupProtein.ToString("F1")g proteina
                                            </div>
                                        </div>
                                    }

                                    <div class="day-summary">
                                        Total: @daySummary.TotalCalories.ToString("F0") kcal | @daySummary.TotalProtein.ToString("F1")g proteina
                                    </div>
                                </div>
                            }
                        }
                    </div>
                }



            }
        </div>
    }

    <!-- Modal pentru înlocuire alimente -->
    <div id="swapModal" class="modal-overlay" onclick="closeSwapModal(event)">
        <div class="modal-content">
            <div class="modal-header">
                <h3>🔄 Alege o alternativă</h3>
                <button class="modal-close" onclick="closeSwapModalDirect()">&times;</button>
            </div>
            <div id="alternativesList">
                <p class="no-alternatives">Se încarcă alternativele...</p>
            </div>
        </div>
    </div>

    <script>
        let currentDay = null;
        let currentMealIndex = null;
        let currentFoodId = null;

        function showSwapButton(element) {
            const btn = element.querySelector('.btn-swap');
            if (btn) btn.style.display = 'block';
        }

        function hideSwapButton(element) {
            const btn = element.querySelector('.btn-swap');
            if (btn) btn.style.display = 'none';
        }

        async function openSwapModal(foodId, mealType, day, mealIndex) {
            currentFoodId = foodId;
            currentDay = day;
            currentMealIndex = mealIndex;

            const modal = document.getElementById('swapModal');
            const alternativesList = document.getElementById('alternativesList');

            modal.style.display = 'flex';
            alternativesList.innerHTML = '<p class="no-alternatives">Se încarcă alternativele...</p>';

            try {
                const csrfToken = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                const response = await fetch(`?handler=Alternatives&foodId=${foodId}&mealType=${mealType}`, {
                    headers: {
                        'RequestVerificationToken': csrfToken || ''
                    }
                });
                const data = await response.json();

                if (data && data.length > 0) {
                    alternativesList.innerHTML = '';
                    data.forEach(alt => {
                        const option = document.createElement('div');
                        option.className = 'alternative-option';
                        option.onclick = () => selectAlternative(alt.id);
                        option.innerHTML = `
                            <div class="alternative-name">${alt.name}</div>
                            <div class="alternative-details">${alt.calories.toFixed(0)} kcal | ${alt.protein.toFixed(1)}g proteina</div>
                        `;
                        alternativesList.appendChild(option);
                    });
                } else {
                    alternativesList.innerHTML = '<p class="no-alternatives">Nu există alternative disponibile pentru acest aliment.</p>';
                }
            } catch (error) {
                alternativesList.innerHTML = '<p class="no-alternatives">Eroare la încărcarea alternativelor.</p>';
                console.error('Error:', error);
            }
        }

        function closeSwapModal(event) {
            if (event.target === document.getElementById('swapModal')) {
                document.getElementById('swapModal').style.display = 'none';
            }
        }

        function closeSwapModalDirect() {
            document.getElementById('swapModal').style.display = 'none';
        }

        async function selectAlternative(newFoodId) {
            try {
                const formData = new FormData();
                formData.append('day', currentDay);
                formData.append('mealIndex', currentMealIndex);
                formData.append('newFoodId', newFoodId);
                formData.append('originalFoodId', currentFoodId);

                const csrfToken = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                const response = await fetch('?handler=SwapFood', {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': csrfToken || ''
                    },
                    body: formData
                });

                const result = await response.json();

                if (result.success) {
                    // Reîncarcă pagina pentru a actualiza planul
                    location.reload();
                } else {
                    alert('Eroare: ' + (result.error || 'Nu s-a putut înlocui alimentul.'));
                }
            } catch (error) {
                alert('Eroare la înlocuirea alimentului.');
                console.error('Error:', error);
            }
        }
    </script>

</body>
</html>